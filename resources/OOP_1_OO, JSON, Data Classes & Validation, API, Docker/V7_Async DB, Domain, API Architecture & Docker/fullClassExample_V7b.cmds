# ==========================================
# STAGE 1: Compilation and Setup Builder
# ==========================================
FROM python:3.11-slim AS builder

WORKDIR /app

# Ensure standard container tools are current
RUN apt-get update && apt-get install -y --no-install-recommends gcc build-essential && rm -rf /var/lib/apt/lists/*

# Cache dependencies independently from core application scripts
COPY requirements.txt .
RUN pip install --no-cache-dir --user -r requirements.txt

# ==========================================
# STAGE 2: Ultra-Lightweight Production Runtime
# ==========================================
FROM python:3.11-slim AS runner

WORKDIR /app

# Pull only the completed binary wheels built during step 1
COPY --from=builder /root/.local /root/.local
COPY app.py .

# Make sure the container process can discover the installed user-level modules
ENV PATH=/root/.local/bin:$PATH
ENV PYTHONUNBUFFERED=1

# Expose standard documentation and route listener lanes
EXPOSE 8000

# Execute server initialization inside container boundary pipelines
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]
